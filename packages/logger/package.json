{
  "name": "@57eme-regiment/nabu-logger",
  "version": "0.1.0",
  "description": "Shared tslog logger factory for 57ème Régiment services",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch"
  },
  "peerDependencies": {
    "tslog": ">=4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
