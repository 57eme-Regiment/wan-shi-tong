  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm --filter @57eme-regiment/auth-contracts dev & ts-node-dev --respawn -r tsconfig-paths/register src/main.ts",
    "build": "pnpm -r --filter @57eme-regiment/auth-contracts --filter @57eme-regiment/auth-server --filter @57eme-regiment/auth-browser build && tsc --project tsconfig.json",
    "start": "node dist/src/main.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "57regiment",
  "license": "ISC",
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@57eme-regiment/auth-contracts": "workspace:*",
    "@57eme-regiment/nabu-errors": "link:../wan-shi-tong/nabu/packages/errors",
    "@57eme-regiment/nabu-fastify": "link:../wan-shi-tong/nabu/packages/fastify",
    "@57eme-regiment/nabu-logger": "link:../wan-shi-tong/nabu/packages/logger",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/fastify-api-reference": "^1.58.0",
    "better-auth": "^1.6.11",
    "discord.js": "^14.26.4",
    "fastify": "^5.0.0",
    "ms": "^2.1.3",
    "reflect-metadata": "^0.2.2",
    "tslog": "^4.10.2",
    "tsyringe": "^4.8.0",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "ts-node -r tsconfig-paths/register prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.0.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.0"
  }
