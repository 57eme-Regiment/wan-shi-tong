{
  "name": "wan-shi-tong",
  "version": "1.0.0",
  "description": "",
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm --filter @57eme-regiment/auth-package dev & ts-node-dev --respawn -r tsconfig-paths/register src/main.ts --watch packages/contract/src",
    "build": "pnpm -r --filter @57eme-regiment/auth-package build && tsc --project tsconfig.json",
    "start": "node dist/src/main.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "ts-node -r tsconfig-paths/register drizzle/seed.ts"
  },
  "keywords": [],
  "author": "57regiment",
  "license": "ISC",
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@57eme-regiment/auth-package": "workspace:*",
    "@57eme-regiment/nabu-errors": "link:../wan-shi-tong/nabu/packages/errors",
    "@57eme-regiment/nabu-fastify": "link:../wan-shi-tong/nabu/packages/fastify",
    "@57eme-regiment/nabu-logger": "link:../wan-shi-tong/nabu/packages/logger",
    "@better-auth/drizzle-adapter": "^1.6.16",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@scalar/fastify-api-reference": "^1.58.0",
    "better-auth": "^1.6.11",
    "discord.js": "^14.26.4",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "ms": "^2.1.3",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.2",
    "tslog": "^4.10.2",
    "tsyringe": "^4.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
